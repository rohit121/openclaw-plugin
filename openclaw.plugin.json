{
  "id": "agentdog",
  "name": "AgentDog",
  "description": "Monitor your AI agent with AgentDog — real-time observability and permission controls",
  "version": "0.2.0",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "apiKey": {
        "type": "string",
        "description": "Your AgentDog API key (starts with ad_)"
      },
      "endpoint": {
        "type": "string",
        "default": "https://agentdog.io/api/v1",
        "description": "AgentDog API endpoint"
      },
      "syncInterval": {
        "type": "number",
        "default": 86400,
        "description": "Config metadata sync interval in seconds (default: 24 h)"
      },
      "permissionsEnabled": {
        "type": "boolean",
        "default": false,
        "description": "Enforce tool-level permission rules defined in the AgentDog dashboard"
      },
      "agentName": {
        "type": "string",
        "description": "Display name for this agent in the AgentDog dashboard"
      }
    },
    "required": ["apiKey"]
  },
  "uiHints": {
    "apiKey": {
      "label": "API Key",
      "placeholder": "ad_xxxxxxxxxxxxx",
      "sensitive": true
    },
    "endpoint": {
      "label": "API Endpoint"
    },
    "syncInterval": {
      "label": "Config Sync Interval (seconds)"
    },
    "permissionsEnabled": {
      "label": "Enable Permissions"
    },
    "agentName": {
      "label": "Agent Name",
      "placeholder": "my-agent"
    }
  }
}